{
  "info": {
    "name": "UrbanPulse API Complete Tests",
    "description": "End-to-end API checks for auth, reports, voting, status management, and admin analytics.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "2ec7b9d1-c9cb-4271-b88d-2c59cf8d9072"
  },
  "item": [
    {
      "name": "00 - Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('body contains ok status', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "01 - API Root",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('returns API message', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.message).to.eql('UrbanPulse API');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Register Citizen",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{citizenEmail}}\",\n  \"password\": \"{{citizenPassword}}\",\n  \"display_name\": \"{{citizenDisplayName}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 201 or 409 if already exists', function () {",
              "  pm.expect([201, 409]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  pm.environment.set('citizenToken', json.token);",
              "}",
              "if (pm.response.code === 409) {",
              "  pm.test('duplicate email handled', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.error).to.include('already');",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Login Citizen",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{citizenEmail}}\",\n  \"password\": \"{{citizenPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.environment.set('citizenToken', json.token);",
              "pm.test('citizen token saved', function () { pm.expect(pm.environment.get('citizenToken')).to.be.a('string'); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 - Create Report",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{citizenToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "category", "value": "illegal_dump", "type": "text" },
            { "key": "title", "value": "Postman test report", "type": "text" },
            { "key": "description", "value": "Created from Postman collection", "type": "text" },
            { "key": "latitude", "value": "42.6977", "type": "text" },
            { "key": "longitude", "value": "23.3219", "type": "text" },
            { "key": "image", "type": "file", "src": "{{imagePath}}" }
          ]
        },
        "url": "{{baseUrl}}/api/reports"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.environment.set('reportId', json.report.id);",
              "pm.test('report ID saved', function () { pm.expect(pm.environment.get('reportId')).to.match(/^[0-9a-f-]{36}$/i); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - List Reports",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/reports?limit=10&offset=0"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('returns reports array', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.reports).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "06 - Get Report By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/reports/{{reportId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('returns expected report id', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.report.id).to.eql(pm.environment.get('reportId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07 - Cast Vote",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{citizenToken}}" }
        ],
        "url": "{{baseUrl}}/api/reports/{{reportId}}/vote"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 201 or 409 if already voted', function () {",
              "  pm.expect([201, 409]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "08 - Remove Vote",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{citizenToken}}" }
        ],
        "url": "{{baseUrl}}/api/reports/{{reportId}}/vote"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200 or 404 if no vote exists', function () {",
              "  pm.expect([200, 404]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "09 - Login Admin",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (!pm.environment.get('adminEmail') || !pm.environment.get('adminPassword')) {",
              "  pm.test('admin credentials configured', function () {",
              "    throw new Error('Set adminEmail/adminPassword in environment before running admin tests.');",
              "  });",
              "} else {",
              "  pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "  const json = pm.response.json();",
              "  pm.environment.set('adminToken', json.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "10 - Update Report Status (Admin)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"new_status\": \"in_progress\",\n  \"comment\": \"Started processing from Postman\"\n}"
        },
        "url": "{{baseUrl}}/api/reports/{{reportId}}/status"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('report status changed', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.report.status).to.eql('in_progress');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "11 - Admin Analytics Summary",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/admin/analytics/summary"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('summary contains total', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.total).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "12 - Admin Analytics Trend",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/admin/analytics/trend?period=weekly"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('trend response is array', function () {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "13 - Admin Analytics Reports Export",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/admin/analytics/reports?category=illegal_dump"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('report export is array', function () {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
